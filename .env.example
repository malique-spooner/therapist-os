# Database
POSTGRES_DB=therapistos
POSTGRES_USER=therapistos
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://therapistos:change-me@postgres:5432/therapistos

# API Security
API_SECRET_KEY=change-me
DATA_SOURCE_ENCRYPTION_KEY=change-me-too
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Malique
OLLAMA_BASE_URL=http://host.docker.internal:11434
LOCAL_QWEN_MODEL=qwen3.5:35b
LOCAL_CHAT_MODEL=qwen2.5:7b-instruct-q3_K_L
OLLAMA_REQUEST_TIMEOUT_SECONDS=45
OLLAMA_KEEP_ALIVE=8h
OLLAMA_PREWARM_ON_STARTUP=true
OLLAMA_NUM_CTX=8192
OLLAMA_THINK=false
PIPER_BINARY=piper
PIPER_VOICE_DIR=/models/piper
PIPER_VOICE_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx
PIPER_VOICE_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx.json
GARMIN_MIN_SYNC_INTERVAL_MINUTES=360
GARMIN_RATE_LIMIT_BACKOFF_MINUTES=1440
GARMIN_SYNC_HOUR=4
GARMIN_SYNC_MINUTE=15
SPOTIFY_SYNC_INTERVAL_MINUTES=5

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
OPENWEATHER_API_KEY=

# Notifications
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=dev-secret-key
TRUSTED_HOSTS=localhost,127.0.0.1
USER_TIMEZONE=Europe/London
USER_LATITUDE=51.5074
USER_LONGITUDE=-0.1278
SEED_DEMO_DATA=true
AUTO_RUN_MIGRATIONS=false
BACKUP_DIR=/backups

# VPS example overrides
# FRONTEND_URL=https://app.example.com
# NEXT_PUBLIC_API_URL=
# TRUSTED_HOSTS=app.example.com,www.app.example.com,localhost,127.0.0.1
# SEED_DEMO_DATA=false
# OLLAMA_BASE_URL=http://your-private-mac-bridge:11434
