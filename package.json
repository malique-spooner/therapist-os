{
  "name": "therapist-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cd frontend && next dev",
    "build": "cd frontend && next build",
    "start": "cd frontend && next start",
    "lint": "cd frontend && next lint",
    "format": "prettier --write .",
    "test": "cd frontend && vitest run --config vitest.config.ts",
    "test:watch": "cd frontend && vitest --config vitest.config.ts",
    "test:frontend": "cd frontend && vitest run --config vitest.config.ts",
    "test:backend:docker": "docker compose run --rm backend-tests",
    "test:all": "npm run test:frontend",
    "test:e2e": "cd frontend && playwright test -c playwright.config.ts",
    "test:e2e:update": "cd frontend && playwright test -c playwright.config.ts --update-snapshots",
    "smoke:deploy": "bash tools/deployment/smoke-test.sh",
    "deploy:vps": "bash tools/deployment/deploy.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "next-pwa": "^5.6.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.54.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^25.0.1",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.1.4"
  }
}
